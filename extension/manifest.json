{
    "manifest_version": 3,
    "name": "PhishShield AI",
    "version": "1.0.0",
    "description": "Real-time AI-powered phishing detection and threat protection.",
    "permissions": [
        "storage",
        "webNavigation",
        "activeTab",
        "tabs",
        "scripting",
        "notifications"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://mail.google.com/*",
                "*://outlook.live.com/*",
                "*://outlook.office.com/*",
                "*://outlook.office365.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "block.html",
                "warning.html",
                "reports.html",
                "assets/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}